---
import type { BuyerQuestion } from "@/types";

interface Props {
  questions: BuyerQuestion[];
}

const { questions } = Astro.props;
---

<div class="space-y-3" role="list">
  {
    questions.map((question) =>
      question.type === "category" ? (
        <div class="border-b border-slate-200 pt-6 pb-2 first:pt-0" data-position={question.position} role="listitem">
          <h2 class="text-base font-bold text-slate-950">{question.text}</h2>
        </div>
      ) : (
        <article
          class="grid grid-cols-[3rem_1fr] gap-3 rounded-md border border-slate-200 bg-white p-4 shadow-sm"
          data-position={question.position}
          role="listitem"
        >
          <span class="flex h-8 w-8 items-center justify-center rounded-full bg-slate-100 text-sm font-semibold text-slate-600">
            {question.position + 1}
          </span>
          <p class="self-center text-sm leading-6 text-slate-800">{question.text}</p>
        </article>
      ),
    )
  }
</div>
