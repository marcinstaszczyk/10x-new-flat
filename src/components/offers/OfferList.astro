---
import type { SavedOffer } from "@/types";

interface Props {
  offers: SavedOffer[];
}

const { offers } = Astro.props;
const formatDate = new Intl.DateTimeFormat("en", {
  dateStyle: "medium",
  timeStyle: "short",
});
---

{
  offers.length === 0 ? (
    <section class="rounded-md border border-slate-200 bg-white p-6 text-sm text-slate-600 shadow-sm">
      <h2 class="text-base font-semibold text-slate-950">No saved offers yet</h2>
      <p class="mt-2 max-w-2xl leading-6">Save pasted offer-page content before running extraction in a later slice.</p>
    </section>
  ) : (
    <div class="space-y-3" role="list">
      {offers.map((offer) => (
        <article class="rounded-md border border-slate-200 bg-white p-4 shadow-sm" role="listitem">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div class="min-w-0">
              <h2 class="text-base font-semibold text-slate-950">
                <a
                  class="break-words transition-colors hover:text-slate-700 hover:underline"
                  href={`/offers/${offer.id}`}
                >
                  {offer.title}
                </a>
              </h2>
              {offer.sourceUrl && (
                <a
                  class="mt-1 block text-sm break-all text-slate-600 transition-colors hover:text-slate-950 hover:underline"
                  href={offer.sourceUrl}
                  rel="noreferrer"
                  target="_blank"
                >
                  {offer.sourceUrl}
                </a>
              )}
            </div>
            <p class="shrink-0 text-sm text-slate-500">Updated {formatDate.format(new Date(offer.updatedAt))}</p>
          </div>
        </article>
      ))}
    </div>
  )
}
