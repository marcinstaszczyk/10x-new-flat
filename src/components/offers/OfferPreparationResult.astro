---
import type {
  AnsweredExtractionQuestion,
  BuyerQuestion,
  OfferExtractionResult,
  UnansweredExtractionQuestion,
} from "@/types";

interface Props {
  result: OfferExtractionResult;
  questions: BuyerQuestion[];
}

type QuestionResultItem = AnsweredExtractionQuestion | UnansweredExtractionQuestion;

const { result, questions } = Astro.props;
const answeredGroups = groupQuestionResults(result.result.answeredQuestions, questions);
const unansweredGroups = groupQuestionResults(result.result.unansweredQuestions, questions);
const formatDate = new Intl.DateTimeFormat("en", {
  dateStyle: "medium",
  timeStyle: "short",
});

function groupQuestionResults<TItem extends QuestionResultItem>(items: TItem[], questionBase: BuyerQuestion[]) {
  const questionMetadata = buildQuestionMetadata(questionBase);
  const groups = new Map<string, TItem[]>();
  const uncategorized: TItem[] = [];

  for (const item of [...items].sort((left, right) => sortQuestionResult(left, right, questionMetadata))) {
    const metadata = questionMetadata.get(item.questionId);
    if (!metadata) {
      uncategorized.push(item);
      continue;
    }

    const groupItems = groups.get(metadata.category) ?? [];
    groupItems.push(item);
    groups.set(metadata.category, groupItems);
  }

  return [
    ...Array.from(groups, ([title, groupItems]) => ({ title, items: groupItems })),
    ...(uncategorized.length ? [{ title: "Uncategorized", items: uncategorized }] : []),
  ];
}

function buildQuestionMetadata(questionBase: BuyerQuestion[]) {
  const metadata = new Map<string, { category: string; position: number }>();
  let currentCategory = "Uncategorized";

  for (const question of questionBase) {
    if (question.type === "category") {
      currentCategory = question.text;
      continue;
    }

    metadata.set(question.id, {
      category: currentCategory,
      position: question.position,
    });
  }

  return metadata;
}

function sortQuestionResult(
  left: QuestionResultItem,
  right: QuestionResultItem,
  metadata: Map<string, { category: string; position: number }>,
) {
  const leftPosition = metadata.get(left.questionId)?.position ?? Number.MAX_SAFE_INTEGER;
  const rightPosition = metadata.get(right.questionId)?.position ?? Number.MAX_SAFE_INTEGER;
  return leftPosition - rightPosition;
}
---

<section class="space-y-6">
  <div class="flex flex-col gap-1 border-b border-slate-200 pb-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm text-slate-500">Generated {formatDate.format(new Date(result.createdAt))}</p>
      <h2 class="text-xl font-semibold text-slate-950">Viewing preparation</h2>
    </div>
    <p class="text-sm text-slate-500">Model: {result.model}</p>
  </div>

  <section class="space-y-4">
    <h3 class="text-base font-semibold text-slate-950">
      Answered questions ({result.result.answeredQuestions.length})
    </h3>
    {
      answeredGroups.length ? (
        answeredGroups.map((group) => (
          <section class="space-y-3">
            <h4 class="text-sm font-semibold text-slate-700">{group.title}</h4>
            <div class="grid gap-3">
              {group.items.map((item) => (
                <article class="rounded-md border border-slate-200 bg-white p-4">
                  <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                    <h5 class="text-sm font-semibold text-slate-950">{item.questionText}</h5>
                    <span class="w-fit rounded-md border border-slate-200 px-2 py-1 text-xs font-medium text-slate-600">
                      {item.confidence} confidence
                    </span>
                  </div>
                  <p class="mt-3 text-sm text-slate-800">{item.answerText}</p>
                  <p class="mt-2 text-xs leading-5 text-slate-500">Evidence: {item.evidenceText}</p>
                </article>
              ))}
            </div>
          </section>
        ))
      ) : (
        <p class="rounded-md border border-slate-200 bg-white p-4 text-sm text-slate-500">No answered questions.</p>
      )
    }
  </section>

  <section class="space-y-4">
    <h3 class="text-base font-semibold text-slate-950">
      Unanswered questions ({result.result.unansweredQuestions.length})
    </h3>
    {
      unansweredGroups.length ? (
        unansweredGroups.map((group) => (
          <section class="space-y-3">
            <h4 class="text-sm font-semibold text-slate-700">{group.title}</h4>
            <div class="grid gap-3">
              {group.items.map((item) => (
                <article class="rounded-md border border-slate-200 bg-white p-4">
                  <h5 class="text-sm font-semibold text-slate-950">{item.questionText}</h5>
                  <p class="mt-2 text-sm text-slate-700">Reason: {item.reason}</p>
                </article>
              ))}
            </div>
          </section>
        ))
      ) : (
        <p class="rounded-md border border-slate-200 bg-white p-4 text-sm text-slate-500">No unanswered questions.</p>
      )
    }
  </section>

  <section class="space-y-4">
    <h3 class="text-base font-semibold text-slate-950">Doubtful facts ({result.result.doubtfulFacts.length})</h3>
    <div class="grid gap-3">
      {
        result.result.doubtfulFacts.length ? (
          result.result.doubtfulFacts.map((fact) => (
            <article class="rounded-md border border-amber-200 bg-white p-4">
              <h4 class="text-sm font-semibold text-slate-950">{fact.label}</h4>
              {fact.value && <p class="mt-2 text-sm text-slate-800">{fact.value}</p>}
              <p class="mt-2 text-sm text-amber-800">Reason: {fact.reason}</p>
              <p class="mt-2 text-xs leading-5 text-slate-500">Evidence: {fact.evidence}</p>
            </article>
          ))
        ) : (
          <p class="rounded-md border border-slate-200 bg-white p-4 text-sm text-slate-500">No doubtful facts.</p>
        )
      }
    </div>
  </section>

  <section class="space-y-4">
    <h3 class="text-base font-semibold text-slate-950">Unmapped facts ({result.result.unmappedFacts.length})</h3>
    <div class="grid gap-3">
      {
        result.result.unmappedFacts.length ? (
          result.result.unmappedFacts.map((fact) => (
            <article class="rounded-md border border-slate-200 bg-white p-4">
              <h4 class="text-sm font-semibold text-slate-950">{fact.label}</h4>
              <p class="mt-2 text-sm text-slate-800">{fact.value}</p>
              <p class="mt-2 text-xs leading-5 text-slate-500">Evidence: {fact.evidence}</p>
            </article>
          ))
        ) : (
          <p class="rounded-md border border-slate-200 bg-white p-4 text-sm text-slate-500">No unmapped facts.</p>
        )
      }
    </div>
  </section>
</section>
