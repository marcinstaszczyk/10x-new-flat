---
import QuestionBaseList from "@/components/questions/QuestionBaseList.astro";
import ResetQuestionBaseForm from "@/components/questions/ResetQuestionBaseForm";
import Layout from "@/layouts/Layout.astro";
import { loadBuyerQuestionBase } from "@/lib/services/questions";
import { createClient } from "@/lib/supabase";

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);
const questionBase = supabase ? await loadBuyerQuestionBase(supabase) : { ok: false };
const questions = questionBase.ok ? questionBase.questions : [];
const hasQuestionBaseError = !questionBase.ok;
const resetState = Astro.url.searchParams.get("reset");
const hasResetSuccess = resetState === "success";
const hasResetError = resetState === "error";
---

<Layout title="Question Base">
  <main class="min-h-screen bg-slate-50 text-slate-950">
    <header class="border-b border-slate-200 bg-white">
      <div class="mx-auto flex max-w-5xl flex-col gap-4 px-4 py-5 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-sm text-slate-500">Signed in as {user?.email}</p>
          <h1 class="mt-1 text-2xl font-semibold tracking-normal text-slate-950">Question base</h1>
        </div>
        <form method="POST" action="/api/auth/signout">
          <button
            type="submit"
            class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-100"
          >
            Sign out
          </button>
        </form>
      </div>
    </header>

    <div class="mx-auto max-w-5xl px-4 py-8">
      {
        hasResetSuccess && (
          <section
            aria-live="polite"
            class="mb-5 rounded-md border border-emerald-200 bg-emerald-50 p-4 text-sm text-emerald-900"
            role="status"
          >
            Your question base was reset to the active template list.
          </section>
        )
      }
      {
        hasResetError && (
          <section
            aria-live="polite"
            class="mb-5 rounded-md border border-red-200 bg-red-50 p-4 text-sm text-red-900"
            role="alert"
          >
            We couldn't reset your question base. Try again in a moment.
          </section>
        )
      }
      {
        hasQuestionBaseError ? (
          <section
            aria-live="polite"
            class="rounded-md border border-red-200 bg-red-50 p-4 text-sm text-red-900"
            role="alert"
          >
            We couldn't load your question base. Try again in a moment.
          </section>
        ) : (
          <section>
            <div class="mb-5 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
              <div>
                <p class="text-sm text-slate-500">Personal copy</p>
                <h2 class="text-lg font-semibold text-slate-950">{questions.length} ordered rows</h2>
              </div>
              <div class="flex flex-col items-start gap-3 sm:items-end">
                <p class="text-sm text-slate-500">Categories stay in the same sequence as the source document.</p>
                <ResetQuestionBaseForm client:load />
              </div>
            </div>
            <QuestionBaseList questions={questions} />
          </section>
        )
      }
    </div>
  </main>
</Layout>
